<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<link rel="stylesheet" href="/css/style.css">
<title>Site de Presentes de Casamento</title>

</head>
<body class="m-4">
   
<div class="container">
  <div class="bg-white card" style="height: 50vh;">
    <h1 class="fonte-diferente mb-5 ">
      Esse é um site de presentes de casamento!</h1>
    <h1 class="fonte-diferente mb-5">Escolha a página do casal do qual você é convidado, e se divirta colaborando com esse momento tão especial!</h1>
  

      <div class="botoes-container">
      <!-- Simulação de casamentos -->

        {{#if casamento.length}}
          {{#each casamento}}
          <div class="">
              <div class="card">
                  <a href="/casamento/{{id}}/detalhes" class="text-decoration-none">
                      <h2>{{titulo}}</h2>
                  </a>
              </div>
          </div>
          {{/each}}
          {{else}}
          <p>Sem Casamentos no momento;</p>
        {{/if}}

    </div>
  </div>   
    
</div>

</body>
</html>

 