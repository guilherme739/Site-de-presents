<div class="container-fluid">
    <header class="row display-6 p-5 text-center background_jm" style="background-color: rgb(253, 152, 215);">
        <h1 class="display-6 ">
            Bem-Vindo
        </h1>
    </header>

    <!-- Sessão para os presentes -->   
    <section class="py-5 bg-soft">
    <div class="container py-5">
       

        <!-- Team Members -->
        <div class="row g-4">
        {{#if presentes.length}}
            {{#each presentes}}
                <!-- Presente Mini Aspirador de pó-->
                <div class="col-lg-3 col-md-6">
                    <div class="team-card h-100">
                        <img src="{{imagem}}" alt="{{nome}}" class="team-image w-100">
                        <div class="p-4">
                            <h5>{{nome}}</h5>
                            <p class="text-muted mb-4">R$ {{preco}}</p>
                        <button role="button" class="btn btn-danger">Presentear</button>
                        </div>
                    </div>
                </div>
            {{/each}}
        {{else}}
            <div>
                <p>
                    Sem Presentes Disponiveis.
                </p>
            </div>
        {{/if}}
        </div>
</section>

           
           
        </div>
    </div>
</div>